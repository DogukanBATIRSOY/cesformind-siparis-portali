// MYSDepo - B2B Gıda Sipariş ve Teslimat Sistemi
// Veritabanı Şeması (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==================== KULLANICI YÖNETİMİ ====================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String   @unique
  password      String
  firstName     String
  lastName      String
  role          String   @default("CUSTOMER") // ADMIN, SALES_REP, DELIVERY, WAREHOUSE, CUSTOMER
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  avatar        String?
  
  mustChangePassword Boolean @default(true) // İlk girişte şifre değiştirme zorunluluğu
  passwordChangedAt  DateTime? // Son şifre değişiklik tarihi
  
  customerId    String?  @unique
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  assignedCustomers Customer[] @relation("SalesRepCustomers")
  createdOrders     Order[]    @relation("OrderCreatedBy")
  deliveries        Delivery[] @relation("DeliveryDriver")
  
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  
  activityLogs  ActivityLog[]
  
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

// ==================== MÜŞTERİ YÖNETİMİ ====================

model Customer {
  id              String   @id @default(cuid())
  code            String   @unique
  companyName     String
  taxNumber       String?  @unique
  taxOffice       String?
  type            String   @default("OTHER") // RESTAURANT, MARKET, HOTEL, CAFE, CATERING, WHOLESALE, OTHER
  status          String   @default("PENDING_APPROVAL") // ACTIVE, INACTIVE, SUSPENDED, PENDING_APPROVAL
  
  contactName     String
  contactPhone    String
  contactEmail    String?
  
  addresses       CustomerAddress[]
  
  creditLimit     Float    @default(0)
  currentBalance  Float    @default(0)
  paymentTermDays Int      @default(0)
  
  priceGroupId    String?
  priceGroup      PriceGroup? @relation(fields: [priceGroupId], references: [id])
  
  user            User?
  salesRepId      String?
  salesRep        User?    @relation("SalesRepCustomers", fields: [salesRepId], references: [id])
  
  orders          Order[]
  payments        Payment[]
  visits          CustomerVisit[]
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CustomerAddress {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  title       String
  address     String
  district    String
  city        String
  postalCode  String?
  country     String   @default("Türkiye")
  
  latitude    Float?
  longitude   Float?
  
  isDefault   Boolean  @default(false)
  isDelivery  Boolean  @default(true)
  isBilling   Boolean  @default(true)
  
  deliveryNotes String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  orders      Order[]
}

model CustomerVisit {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  userId      String
  
  visitDate   DateTime
  visitType   String
  notes       String?
  
  latitude    Float?
  longitude   Float?
  
  createdAt   DateTime @default(now())
}

// ==================== ÜRÜN YÖNETİMİ ====================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  
  products    Product[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?
  isActive    Boolean   @default(true)
  
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  barcode         String?  @unique
  name            String
  description     String?
  
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  brandId         String?
  brand           Brand?   @relation(fields: [brandId], references: [id])
  
  unit            String
  unitWeight      Float?
  packSize        Int      @default(1)
  
  basePrice       Float
  costPrice       Float?
  taxRate         Float    @default(18)
  
  minStock        Int      @default(0)
  maxStock        Int?
  
  images          ProductImage[]
  
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, OUT_OF_STOCK, DISCONTINUED
  isFeatured      Boolean  @default(false)
  
  stockMovements  StockMovement[]
  orderItems      OrderItem[]
  warehouseStocks WarehouseStock[]
  priceGroupItems PriceGroupItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isMain    Boolean @default(false)
}

// ==================== FİYAT GRUPLARI ====================

model PriceGroup {
  id          String           @id @default(cuid())
  name        String
  description String?
  discount    Float            @default(0)
  isActive    Boolean          @default(true)
  
  customers   Customer[]
  items       PriceGroupItem[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model PriceGroupItem {
  id           String     @id @default(cuid())
  priceGroupId String
  priceGroup   PriceGroup @relation(fields: [priceGroupId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  price        Float?
  discount     Float?
  
  @@unique([priceGroupId, productId])
}

// ==================== DEPO VE STOK YÖNETİMİ ====================

model Warehouse {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  address     String?
  city        String?
  isActive    Boolean          @default(true)
  isDefault   Boolean          @default(false)
  
  stocks      WarehouseStock[]
  movements   StockMovement[]
  users       User[]
  orders      Order[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model WarehouseStock {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  
  quantity    Float     @default(0)
  reserved    Float     @default(0)
  
  updatedAt   DateTime  @updatedAt
  
  @@unique([warehouseId, productId])
}

model StockMovement {
  id            String    @id @default(cuid())
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  
  type          String    // IN, OUT, TRANSFER, ADJUSTMENT, RETURN
  quantity      Float
  previousStock Float
  newStock      Float
  
  referenceType String?
  referenceId   String?
  
  notes         String?
  createdBy     String
  createdAt     DateTime  @default(now())
}

// ==================== SİPARİŞ YÖNETİMİ ====================

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  
  addressId       String
  address         CustomerAddress @relation(fields: [addressId], references: [id])
  
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  
  status          String   @default("DRAFT") // DRAFT, PENDING, CONFIRMED, PREPARING, READY, OUT_FOR_DELIVERY, DELIVERED, CANCELLED, RETURNED
  source          String   @default("WEB") // WEB, MOBILE, FIELD, PHONE
  
  orderDate       DateTime @default(now())
  requestedDate   DateTime?
  confirmedDate   DateTime?
  deliveredDate   DateTime?
  
  subtotal        Float
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float
  shippingAmount  Float    @default(0)
  totalAmount     Float
  
  customerNote    String?
  internalNote    String?
  
  items           OrderItem[]
  delivery        Delivery?
  payments        Payment[]
  
  createdById     String
  createdBy       User     @relation("OrderCreatedBy", fields: [createdById], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  
  quantity    Float
  unit        String
  unitPrice   Float
  discount    Float   @default(0)
  taxRate     Float
  
  subtotal    Float
  taxAmount   Float
  total       Float
  
  notes       String?
}

// ==================== TESLİMAT YÖNETİMİ ====================

model Delivery {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  
  driverId        String?
  driver          User?    @relation("DeliveryDriver", fields: [driverId], references: [id])
  
  routeId         String?
  route           DeliveryRoute? @relation(fields: [routeId], references: [id])
  
  status          String   @default("PENDING") // PENDING, ASSIGNED, PICKED_UP, IN_TRANSIT, DELIVERED, FAILED, RETURNED
  
  plannedDate     DateTime?
  plannedTimeStart String?
  plannedTimeEnd   String?
  
  actualDate      DateTime?
  
  currentLat      Float?
  currentLng      Float?
  lastLocationAt  DateTime?
  
  receiverName    String?
  receiverPhone   String?
  signature       String?
  deliveryPhoto   String?
  
  driverNote      String?
  failureReason   String?
  
  sequenceOrder   Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  locationHistory DeliveryLocation[]
}

model DeliveryLocation {
  id          String   @id @default(cuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  
  latitude    Float
  longitude   Float
  accuracy    Float?
  speed       Float?
  
  recordedAt  DateTime @default(now())
}

model DeliveryRoute {
  id            String     @id @default(cuid())
  name          String
  date          DateTime
  driverId      String
  
  status        String     @default("PLANNED")
  
  totalDistance Float?
  totalDuration Int?
  totalStops    Int        @default(0)
  completedStops Int       @default(0)
  
  deliveries    Delivery[]
  
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ==================== ÖDEME VE TAHSİLAT ====================

model Payment {
  id              String   @id @default(cuid())
  paymentNumber   String   @unique
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id])
  
  type            String   // CASH, CREDIT_CARD, BANK_TRANSFER, CHECK, PROMISSORY_NOTE
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED, CANCELLED, REFUNDED
  
  amount          Float
  
  paymentDate     DateTime @default(now())
  dueDate         DateTime?
  
  referenceNumber String?
  bankName        String?
  
  notes           String?
  
  collectedBy     String?
  collectedAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== AKTİVİTE LOGLARI ====================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  action      String
  entityType  String
  entityId    String?
  
  oldData     String?
  newData     String?
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
}

// ==================== SİSTEM AYARLARI ====================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String   @default("general")
  
  updatedAt DateTime @updatedAt
}

// ==================== BİLDİRİMLER ====================

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // ORDER_NEW, ORDER_STATUS, PAYMENT_RECEIVED, STOCK_LOW, DELIVERY_ASSIGNED, DELIVERY_COMPLETED, SYSTEM
  title       String
  message     String
  data        String?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
}
