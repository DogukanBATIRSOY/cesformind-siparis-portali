# Veritabanı
DATABASE_URL="postgresql://postgres:password@localhost:5432/mysdepo?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Sunucu
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# Dosya Yükleme
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Redis (opsiyonel - offline sync için)
REDIS_URL="redis://localhost:6379"
